{
  "name": "@dancampari/agent-harness-kit",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "CLI local para preparar, instalar, versionar e validar estruturas de Agent Harness Engineering (Codex, Claude Code, Cursor). Não chama nenhuma API de LLM.",
  "type": "module",
  "license": "MIT",
  "author": "Dan Campari <dan.campari@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dancampari/agent-harness-kit.git"
  },
  "homepage": "https://github.com/dancampari/agent-harness-kit#readme",
  "bugs": {
    "url": "https://github.com/dancampari/agent-harness-kit/issues"
  },
  "engines": {
    "node": ">=18.17"
  },
  "bin": {
    "harness": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup && node scripts/copy-templates.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "prepare": "node scripts/prepare.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent",
    "harness",
    "codex",
    "claude-code",
    "cli",
    "ai-agents",
    "automation"
  ],
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.1",
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "fs-extra": "^11.2.0",
    "ink": "^5.1.0",
    "ora": "^8.1.1",
    "react": "^18.3.1",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "packageManager": "pnpm@9.12.0"
}
